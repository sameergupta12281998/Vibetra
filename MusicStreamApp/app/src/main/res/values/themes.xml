<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MusicStreamApp" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorPrimary">@color/accent_teal</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/accent_teal</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorControlActivated">@color/accent_teal</item>
        <item name="android:navigationBarColor">@color/bg_secondary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
        <item name="materialButtonStyle">@style/Widget.MusicStream.Button</item>
    </style>

    <style name="Widget.MusicStream.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/accent_teal</item>
        <item name="android:textColor">@color/white</item>
    </style>
</resources>
